# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/yarn-error.log

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore application configuration
/config/application.yml

# Ignore environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore database
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all files in public/assets (but not the directory itself)
/public/assets
.byebug_history

# Ignore files generated by Heroku
/config/database.yml

# Ignore IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore Docker volumes
postgres_data/

# Rails 8系の新機能関連ファイル

# Propshaft (新しいアセットパイプライン)
/public/assets
/public/packs
/public/packs-test

# Solid Cache
/db/cache_schema.rb

# Solid Queue
/db/queue_schema.rb

# Solid Cable
/db/cable_schema.rb

# Kamal (デプロイメントツール)
.kamal/
/config/deploy.yml

# Thruster (パフォーマンスツール)
/thruster.log

# Importmap関連
/vendor/javascript

# 開発用ファイル
*.log
*.pid
*.seed
*.pid.lock

# テスト関連
/coverage/
/test/tmp/
/test/version_tmp/
/tmp/

# キャッシュ関連
.cache/
.sass-cache/
*.sass.map
*.css.map

# その他のRails 8系ファイル
/config/credentials/*.key
/config/credentials.yml.enc
/config/storage.yml
/config/cache.yml
/config/queue.yml
/config/recurring.yml

# 開発用gemの設定
.rubocop.yml
.rubocop_todo.yml
